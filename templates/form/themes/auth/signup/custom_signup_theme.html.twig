{% block signup_row %}
                                {{ form_start(form) }}
                                    <div class="mb-3">
                                        {{ form_label(form.full_name,'Name', {label_attr :{'class': 'form-label'}}) }}
                                        {{ form_widget(form.full_name, { attr: {'class': 'form-control'} }) }}
                                        {{ form_errors(form.full_name) }}
                                    </div>
                                    <div class="mb-3">
                                        {{ form_label(form.email, 'Email Address', {label_attr :{'class': 'form-label'}}) }}
                                        {{ form_widget(form.email, { attr: {'class': 'form-control'} }) }}
                                        {{ form_errors(form.email) }}
                                    </div>
                                    <div class="mb-3">
                                        {{ form_label(form.password,'Password', {label_attr :{'class': 'form-label'}}) }}
                                        {{ form_widget(form.password, { attr: {'class': 'form-control'} }) }}
                                        {{ form_errors(form.password) }}
                                    </div>
                                    <div class="mb-3">
                                        {{ form_label(form.confirm_password,'Confirm Password', {label_attr :{'class': 'form-label'}}) }}
                                        {{ form_widget(form.confirm_password, { attr: {'class': 'form-control'} }) }}
                                        {{ form_errors(form.confirm_password) }}
                                    </div>
                                    <div class="mb-3 form-check">
                                        {{ form_widget(form.terms, { attr: {'class': 'form-check-input'} }) }}
                                        <label class="form-check-label" for="terms">
                                            I agree to the <a href="#" class="text-decoration-none">Terms & Conditions</a>
                                        </label>
                                    </div>
                                    <div class="d-grid">
                                        {{ form_widget(form.submit, { attr: { class: 'btn btn-success btn-lg' } }) }}
                                    </div>
                                {{ form_end(form) }}
{% endblock signup_row %}