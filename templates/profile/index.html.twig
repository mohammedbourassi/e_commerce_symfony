{% extends 'base.html.twig' %}

{% block title %}My Profile - Our Store{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block body %}
    {% include '_navbar.html.twig' %}

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">My Profile</h3>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <img src="{{ asset('images/profile.png') }}" class="rounded-circle mb-3" alt="User Avatar" width="150" height="150">
                            <h5 class="card-title">{{ user.fullName }}</h5>
                            <p class="text-muted">{{ user.email }}</p>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="fw-bold">Full Name:</label>
                                <p>{{ user.fullName }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold">Email:</label>
                                <p>{{ user.email }}</p>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="{{ path('home') }}" class="btn btn-outline-primary">Back to products</a>
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger">Logout</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
