{% extends 'base.html.twig' %}
{% block title %}
    <title>Electronics - Our Store</title>
{% endblock %}
{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}
{% block body %}
     {% include '_navbar.html.twig' %}

    <!-- Breadcrumb -->
    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="index.html" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Categories</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{categoryWithProducts[0].name}}</li>
            </ol>
        </nav>
    </div>

    <!-- Jumbotron -->
    <div class="container my-4">
        <div class="p-5 mb-4 bg-primary bg-gradient text-white rounded-3">
            <div class="container-fluid py-3">
                <h1 class="display-4 fw-bold">{{categoryWithProducts[0].name}}</h1>
                <p class="col-md-8 fs-5">{{categoryWithProducts[0].description}}</p>
                <span class="badge bg-light text-dark fs-6">{{categoryWithProducts[0].products|length}} Products Available</span>
            </div>
        </div>
    </div>

    <!-- Products by Category -->
    <div class="container mb-5">
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <h3>Browse {{categoryWithProducts[0].name}}</h3>
                    <div class="btn-group" role="group">
                        <button type="button" class="btn btn-outline-secondary active">Grid</button>
                        <button type="button" class="btn btn-outline-secondary">List</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in categoryWithProducts[0].products %}
            <div class="col">
                <div class="card h-100">
                    <img src={{ asset(product.image) }} class="card-img-top" alt="{{ product.name }}">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">{{ categoryWithProducts[0].name }}</span>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text fw-bold text-success">${{ product.price|number_format(2) }}</p>
                        <a href="{{ path('product_details', {'id': product.id}) }}" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        
        <!-- Pagination -->
        <nav aria-label="Product pagination" class="mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Previous</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Next</a>
                </li>
            </ul>
        </nav>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>Our Store</h5>
                    <p>Quality products at affordable prices</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>&copy; 2024 Our Store. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>
{% endblock %}
